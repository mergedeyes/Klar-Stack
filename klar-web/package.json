{
  "name": "klar-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "fuser -k 3000/tcp 3001/tcp 1025/tcp 8025/tcp 2>/dev/null || true",
    "start:mailhog": "mailhog",
    "dev:base": "next dev --turbo --port 3001",
    "start:backend": "cd ../Klar && cargo sqlx migrate run && cargo run",
    "start:frontend": "wait-on tcp:127.0.0.1:3000 && npm run dev:base",
    "dev": "npm run clean && concurrently --kill-others --names \"MAIL\",\"RUST\",\"NODE\" --prefix-colors \"cyan,magenta,green\" \"npm run start:mailhog\" \"npm run start:backend\" \"npm run start:frontend\"",
    "build": "next build",
    "lint": "eslint",
    "start:base": "next start --port 3001",
    "run:backend:prod": "cd ../Klar && ENV=production ./target/release/Klar",
    "run:frontend:prod": "wait-on tcp:127.0.0.1:3000 && npm run start:base",
    "prod": "npm run clean && concurrently --kill-others --names \"MAIL\",\"RUST\",\"NODE\" --prefix-colors \"cyan,magenta,green\" \"npm run start:mailhog\" \"npm run run:backend:prod\" \"npm run run:frontend:prod\""
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "next": "^16.2.11",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.75.0",
    "shadcn": "^4.6.0",
    "sharp": "^0.35.3",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.10"
  }
}
